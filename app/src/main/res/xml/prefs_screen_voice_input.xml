<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto" app:orderingFromXml="true">

	<!-- Rows are added by VoiceInputScreen, one per enabled language: real size from the pinned
	     catalogue, download state, and tap to download or delete. -->
	<PreferenceCategory
		app:key="category_voice_models"
		app:title="@string/pref_voice_models"
		app:summary="@string/pref_voice_models_summary"
		app:singleLineTitle="true" />

	<PreferenceCategory
		app:key="category_voice_hotkey"
		app:title="@string/pref_voice_hotkey"
		app:singleLineTitle="true" />

</PreferenceScreen>
