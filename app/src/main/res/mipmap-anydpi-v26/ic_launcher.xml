<?xml version="1.0" encoding="utf-8"?>
<!-- SideType launcher icon (SID-74): the rendered brand mark as the adaptive foreground, over the
     mid-silver brand ground. No monochrome layer — the SP-01 (Android 12) never renders one, as
     SideHome uses getApplicationIcon(). -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
	<background android:drawable="@color/ic_launcher_background"/>
	<foreground android:drawable="@mipmap/ic_launcher_foreground"/>
</adaptive-icon>
