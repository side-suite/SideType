# Copy this file to `keystore.properties` (which is git-ignored) and fill in your values to
# sign release builds. Generate a keystore once and reuse it for EVERY release — updates only
# install over each other if they share the same signing key.
#
# Generate a key:
#   keytool -genkey -v -keystore sidetype-release.jks \
#       -keyalg RSA -keysize 2048 -validity 10000 -alias sidetype
#
# Then set the paths/passwords below (storeFile is relative to the repo root):
storeFile=sidetype-release.jks
storePassword=CHANGE_ME
keyAlias=sidetype
keyPassword=CHANGE_ME
